# 应用配置
APP_NAME=SerPro
APP_VERSION=0.1.0
DEBUG=True

# 数据库配置
DATABASE_URL=postgresql://serapro:serapro_secret@localhost:5432/serapro
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=serapro:

# 安全配置
# 生产环境请使用：openssl rand -hex 32 生成新的密钥
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MASTER_KEY=0123456789abcdef0123456789abcdef

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=

# 火山引擎 (豆包) 配置
VOLCENGINE_API_KEY=
VOLCENGINE_MODEL=

# 阿里云 (通义千问) 配置
ALIBABA_API_KEY=
ALIBABA_MODEL=

# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# AI Provider 选择 (openai, volcengine, alibaba, deepseek, auto)
AI_PROVIDER=auto

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 限流配置
RATE_LIMIT_PER_MINUTE=100

# 邮件通知 (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# 短信通知
SMS_PROVIDER=aliyun
SMS_API_KEY=
SMS_SECRET=

# 钉钉通知
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
